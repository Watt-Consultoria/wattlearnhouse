{
  "name": "wattlearn",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "services:up": "docker-compose -f src/infra/compose.yaml up -d && npm run prisma:migrate",
    "services:down": "docker-compose -f src/infra/compose.yaml down",
    "services:stop": "docker-compose -f src/infra/compose.yaml stop",
    "db:wait": "wait-on tcp:localhost:5432",
    "prisma:migrate": "npm run db:wait && npx prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "prisma db seed",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "jose": "6.2.3",
    "lucide-react": "1.24.0",
    "next": "16.2.10",
    "pg": "8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "4.13.0",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4",
    "@types/node": "20",
    "@types/pg": "8.20.0",
    "@types/react": "19",
    "@types/react-dom": "19",
    "dotenv": "17.4.2",
    "eslint": "9",
    "eslint-config-next": "16.2.10",
    "prisma": "7.8.0",
    "tailwindcss": "4",
    "tsx": "4.23.0",
    "typescript": "5",
    "wait-on": "9.0.10"
  }
}
