generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["wattlearnhouse"]
}

enum UserRole {
  student
  teacher
  admin

  @@schema("wattlearnhouse")
}

enum CertificateKind {
  student_completion
  teacher_authorship

  @@schema("wattlearnhouse")
}
model User {
  id        String   @id @default(uuid())
  googleId  String   @unique @map("google_id")
  name      String
  email     String   @unique
  avatarUrl String?  @map("avatar_url")
  fullName  String?  @map("full_name")
  cpf       String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)
  role      UserRole @default(student)

  courses        Course[]
  lessonProgress LessonProgress[]
  quizAttempts   QuizAttempt[]
  enrollments    Enrollment[]
  certificates   Certificate[]

  @@map("users")
  @@schema("wattlearnhouse")
}

model Course {
  id            String      @id @default(uuid())
  teacherId     String      @map("teacher_id")
  title         String
  description   String?
  category      String
  coverImageUrl String?     @map("cover_image_url")
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.Timestamptz(3)

  teacher      User          @relation(fields: [teacherId], references: [id])
  modules      Module[]
  enrollments  Enrollment[]
  certificates Certificate[]

  @@index([teacherId], map: "idx_courses_teacher_id")
  @@map("courses")
  @@schema("wattlearnhouse")
}

model Enrollment {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  courseId    String   @map("course_id")
  enrolledAt  DateTime @default(now()) @map("enrolled_at") @db.Timestamptz(3)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId], map: "idx_enrollments_user_course")
  @@index([courseId], map: "idx_enrollments_course_id")
  @@map("enrollments")
  @@schema("wattlearnhouse")
}

model Certificate {
  id                  String          @id @default(uuid())
  userId              String          @map("user_id")
  courseId            String          @map("course_id")
  kind                CertificateKind @default(student_completion)
  verificationCode    String          @unique @map("verification_code")
  fullNameSnapshot    String          @map("full_name_snapshot")
  cpfSnapshot         String          @map("cpf_snapshot")
  courseTitleSnapshot String          @map("course_title_snapshot")
  modulesSnapshot     Json            @map("modules_snapshot")
  issuedAt            DateTime        @default(now()) @map("issued_at") @db.Timestamptz(3)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId, kind], map: "idx_certificates_user_course_kind")
  @@index([courseId], map: "idx_certificates_course_id")
  @@map("certificates")
  @@schema("wattlearnhouse")
}

model Module {
  id        String   @id @default(uuid())
  courseId  String   @map("course_id")
  title     String
  order     Int
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]
  quiz    Quiz?

  @@index([courseId], map: "idx_modules_course_id")
  @@map("modules")
  @@schema("wattlearnhouse")
}

model Lesson {
  id              String   @id @default(uuid())
  moduleId        String   @map("module_id")
  title           String
  content         String
  order           Int
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  module   Module            @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress LessonProgress[]

  @@index([moduleId], map: "idx_lessons_module_id")
  @@map("lessons")
  @@schema("wattlearnhouse")
}

model Quiz {
  id        String   @id @default(uuid())
  moduleId  String   @unique @map("module_id")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  module    Module         @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  @@map("quizzes")
  @@schema("wattlearnhouse")
}

model QuizQuestion {
  id           String @id @default(uuid())
  quizId       String @map("quiz_id")
  question     String
  options      String[]
  correctIndex Int    @map("correct_index")
  explanation  String
  order        Int

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId], map: "idx_quiz_questions_quiz_id")
  @@map("quiz_questions")
  @@schema("wattlearnhouse")
}

model QuizAttempt {
  id             String   @id @default(uuid())
  quizId         String   @map("quiz_id")
  userId         String   @map("user_id")
  score          Int
  totalQuestions Int      @map("total_questions")
  passed         Boolean
  answers        Json
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([quizId], map: "idx_quiz_attempts_quiz_id")
  @@index([userId], map: "idx_quiz_attempts_user_id")
  @@map("quiz_attempts")
  @@schema("wattlearnhouse")
}

model LessonProgress {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  lessonId    String   @map("lesson_id")
  completedAt DateTime @default(now()) @map("completed_at") @db.Timestamptz(3)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId], map: "idx_lesson_progress_user_lesson")
  @@index([lessonId], map: "idx_lesson_progress_lesson_id")
  @@map("lesson_progress")
  @@schema("wattlearnhouse")
}