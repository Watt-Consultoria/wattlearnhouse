# LOCAL POSTGRES DOCKER CONTAINER CONFIGURATION
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="wattlearn"
POSTGRES_PORT=5432
POSTGRES_URL="postgres://postgres:postgres@localhost:5432/wattlearn"

# GOOGLE OAUTH CONFIGURATION
GOAUTH_CLIENT_ID="your_google_client_id"
GOAUTH_CLIENT_SECRET="your_google_client_secret"
GOAUTH_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# PRISMA DATABASE CONFIGURATION
# Local dev (Docker Postgres): DATABASE_URL and DIRECT_URL can be the same.
#
# Supabase (staging/production), from Project Settings > Database > Connect:
#   DATABASE_URL = Transaction pooler (port 6543, add ?pgbouncer=true) — used
#                  by the running app (src/infra/database.ts).
#   DIRECT_URL   = Session pooler (port 5432, SAME pooler.supabase.com host,
#                  just a different port) — used by Prisma Migrate.
#   Do NOT use the raw "Direct connection" (db.<project-ref>.supabase.co) for
#   DIRECT_URL — it's IPv6-only and Vercel builds are IPv4-only, which causes
#   `prisma migrate deploy` to fail with an obscure "migration persistence is
#   not initialized" error. Use the Session pooler variant instead, unless
#   the Supabase project has the IPv4 add-on enabled.
# Tables live in the "wattlearnhouse" schema (see prisma/schema.prisma).
DATABASE_URL="postgres://postgres:postgres@localhost:5432/wattlearn"
DIRECT_URL="postgres://postgres:postgres@localhost:5432/wattlearn"

# SESSION CONFIGURATION
SESSION_SECRET="your_session_secret"

# APPLICATION BASE URL
BASE_URL="http://localhost:3000"